### WSL `Ubuntu24.04`下`.env`示例
## 🍎 macOS
# 要安装的 macOS 版本，例如 `14` 或 `sonoma`。默认为`14`。
VERSION=26
# OpenCore 使用的 Mac 型号标识符。默认为`iMacPro1,1`。
MODEL=iMacPro1,1
# Mac 序列号。未设置时自动生成。默认为空。
# SN=
# Mac 主板序列号。未设置时自动生成。默认为空。
# MLB=
# Mac 系统 UUID。未设置时自动生成。默认为空。
# UUID=

## 🧠 CPU 和内存
# 分配给虚拟机的 CPU 核心数。也可以设置为 `max` 或 `half`。默认为`1`。
CPU_CORES=half
# 要使用的 QEMU CPU 模型。未设置时为 Intel/AMD 自动选择。默认为空。
# CPU_MODEL=
# 额外的 QEMU CPU 标志。默认为空。
# CPU_FLAGS=
# 启用 KVM 硬件加速。设置为 `N` 以禁用。默认为`Y`。
KVM=Y
# 分配给虚拟机的 RAM 大小，例如 `4G`、`8G`、`max` 或 `half`。默认为`4G`。
RAM_SIZE=16G
# 在启动虚拟机之前检查主机是否有足够的可用内存。默认为`Y`。
RAM_CHECK=Y

## ⚙️ 系统
BOOT="ubuntu"
# QEMU 机器类型。默认为`q35`。
MACHINE=q35
# 启用或禁用 QEMU HPET 定时器。默认为`off`。
HPET=off
# 启用或禁用 QEMU VMware 端口。默认为`off`。
VMPORT=off
# 附加到生成的命令行的额外原始 QEMU 参数。默认为空。
# ARGUMENTS=

## 🚀 启动
# 显示 OpenCore 启动选择界面，如果需要进入恢复模式请设置为`Y`。默认为`N`。
PICKER=N
# QEMU 安全启动标志。默认为`off`。
SECURE=off
# 启用自定义启动图标。默认为`Y`。
LOGO=Y
# OpenCore 启动介质的启动优先级索引。默认为`9`。
BOOT_INDEX=9
# QEMU USB 控制器设置。设置为 `no*` 值以禁用。默认为`nec-usb-xhci,id=xhci -device usb-kbd,bus=xhci.0 -global nec-usb-xhci.msi=off`。
USB="nec-usb-xhci,id=xhci -device usb-kbd,bus=xhci.0 -global nec-usb-xhci.msi=off"

## 💾 存储
# 主数据磁盘的大小。默认为`64G`。
DISK_SIZE=128G
# 磁盘镜像格式，通常为 `raw` 或 `qcow2`。默认为`raw`。
DISK_FMT=qcow2
# 磁盘控制器/设备类型，例如 `sata`、`scsi`、`nvme` 或 `blk`。默认为`blk`。
DISK_TYPE=blk
# QEMU 磁盘缓存模式，例如 `none` 或 `writeback`。默认为`none`。
DISK_CACHE=none
# QEMU 磁盘 I/O 模式，例如 `native`、`threads` 或 `io_uring`。默认为`native`。
DISK_IO=native
# 为数据磁盘启用 TRIM/unmap 支持。默认为`unmap`。
DISK_DISCARD=unmap
# 报告给客户机的旋转速率。对于类 SSD 存储请使用 `1`。默认为`1`。
DISK_ROTATION=1
# 创建 qcow2 磁盘时使用的额外选项。默认为空。
# DISK_FLAGS=
# 创建数据磁盘时预分配磁盘空间。默认为`N`。
ALLOCATE=N
# 用于磁盘、固件变量和生成文件的存储目录。默认为`/storage`。
STORAGE=/storage

## 🌐 网络
# 网络模式。常用值为 `Y`（NAT）、`passt`、`slirp` 或 `N`（禁用网络）。默认为`Y`。
NETWORK=Y
# 启用 DHCP/macvtap 模式，以便虚拟机从外部 LAN 获取地址。默认为`N`。
DHCP=N
# 客户机 IP 地址覆盖。默认为空。
# IP=
# 客户机网络适配器 MAC 地址。未设置时自动生成。默认为空。
# MAC=
# 分配给虚拟机的主机名。默认为`macOS`。
HOST=macOS
# 要使用的主机/容器网络接口。默认为`eth0`。
DEV=eth0
# 客户机接口使用的网络 MTU。默认为空。
# MTU=
# IPv4 子网掩码。默认为`255.255.255.0`。
MASK=255.255.255.0
# TAP/macvtap 接口名称。默认为`qemu`。
TAP=qemu
# 用于 NAT 网络的网桥名称。默认为`docker`。
BRIDGE=docker
# QEMU 网络适配器模型。默认为`virtio-net-pci`。
ADAPTER=virtio-net-pci
# 为主机/容器端运行的服务保留的端口。默认为空。
# HOST_PORTS=
# 使用用户模式网络时转发到虚拟机的额外端口。默认为空。
# USER_PORTS=
# 额外的 dnsmasq 选项。默认为空。
# DNSMASQ_OPTS=
# 启用 dnsmasq 日志跟踪。默认为`N`。
DNSMASQ_DEBUG=N
# 禁用内部 dnsmasq 解析器。默认为`N`。
DNSMASQ_DISABLE=N
# 额外的 passt 选项。默认为空。
# PASST_OPTS=
# 启用 passt 调试输出。默认为`N`。
PASST_DEBUG=N
# 宿主机HTTP 代理（用于下载安装环境）。默认为空。
# HTTP_PROXY=http://172.30.0.1:7890
# HTTPS_PROXY=http://172.30.0.1:7890
# ALL_PROXY=socks5://172.30.0.1:7890
http_proxy=http://172.30.0.1:7890
https_proxy=http://172.30.0.1:7890
all_proxy=socks5://172.30.0.1:7890
GATEWAY_PROXY=http://172.30.0.1:7890
# 安装环境后禁用代理。默认为`N`。
DISABLE_PROXY=N

## 🖥️ 显示
# 为 macOS/OpenCore 配置的显示宽度。默认为`1920`。
WIDTH=1920
# 为 macOS/OpenCore 配置的显示高度。默认为`1080`。
HEIGHT=1080
# 显示后端。常用值为 `web`、`vnc`、`disabled` 或 `none`。默认为`web`。
DISPLAY=web
# QEMU 视频适配器VGA设备，可选值为`none`、`std`、`cirrus`、`vmware`、`virtio`。
# 为`none`时由`-device`指定，为`std`时同`-device VGA`，为`cirrus`时同`-device cirrus-vga`、
# 为`vmware`时同`-device vmware-svga`，为`virtio`时同`-device virtio-vga`。
# 默认为`vmware`。
VGA=vmware
# QEMU 视频适配器设备。默认为`vmware-svga`。
VGA_DEVICE=vmware-svga
# 启用 Intel iGPU 加速。实验性功能。默认为`N`。
GPU=Y
# 用于 GPU 加速的渲染节点。默认为`/dev/dri/renderD128`。
RENDERNODE=/dev/dri/renderD128

## 🌍 Web UI
# 启用或禁用 Web 界面。默认为`Y`。
WEB=Y
# Web 界面端口。默认为`8006`。
WEB_PORT=8006
# VNC 服务器端口。默认为`5900`。
VNC_PORT=5900
# QEMU/noVNC 使用的 WebSocket 端口。默认为`5700`。
WSS_PORT=5700
# 内部 websocketd 端口。默认为`8004`。
WSD_PORT=8004
# 为 Web 界面启用密码保护。默认为`N`。
PROTECT=Y
# HTTP 基本认证用户名。默认为`Docker`。
USERNAME=Docker
# HTTP 基本认证密码。默认为`admin`。
PASSWORD=admin
# PASS=admin
# 若设为 `N`，禁用脚本启动独立的nginx实例，默认为禁用
# 如果你已经在使用nginx运行网站，建议设为 `N`，否则会导致端口冲突
# NoVNC Web界面配置文件在`/etc/nginx/sites-enabled/web.conf`
NGINX=N

## 🎈 内存气球
# 另请参阅 [动态内存分配](https://github.com/qemus/qemu/blob/master/docs/ballooning.md) 以获取使用说明和重要注意事项。
# 启用动态内存气球。默认为`N`。
BALLOONING=N
# 启用气球监视器的调试输出。默认为`N`。
BALLOONING_DEBUG=N
# 气球设备的最低内存目标。默认为`33%`。
BALLOONING_MIN_MEM=33%
# 目标主机 RAM 使用百分比。默认为`80.0`。
BALLOONING_RAM_THRESHOLD=80.0
# 主机 RAM 使用百分比阈值，达到此值气球操作将变得更加激进。默认为`90.0`。
BALLOONING_RAM_THRESHOLD_HARD=90.0
# PSI 内存压力级别，达到此值气球操作开始更激进地响应。默认为`10.0`。
BALLOONING_PSI_PRESSURE=10.0
# PSI 内存压力级别，达到此值气球操作将达到最强响应。默认为`50.0`。
BALLOONING_PSI_PRESSURE_MAX=50.0
# 更新气球目标前的最小内存变化量。默认为`128M`。
BALLOONING_HYSTERESIS=128M
# 气球控制器的比例增益。默认为`0.5`。
BALLOONING_KP=0.5
# 气球控制器的积分增益。默认为`0.05`。
BALLOONING_KI=0.05
# 轮询间隔（秒）。默认为`5`。
BALLOONING_INTERVAL=5

## 🔌 关机
# 启用优雅的 ACPI 关机。默认为`Y`。
SHUTDOWN=Y
# 等待虚拟机关机时的超时时间。默认为`115`。
TIMEOUT=115

## 🐞 调试
# QEMU 目录。默认为`/run/shm`。
QEMU_DIR="/run/shm"
# 启用详细的调试输出。默认为`N`。
DEBUG=N
# 启用 shell 命令跟踪。默认为`N`。
TRACE=N
# QEMU 串行设备设置。默认为`mon:stdio`。
SERIAL=mon:stdio
# QEMU 监视器设备设置。默认为`unix:$QEMU_DIR/monitor.sock,server,wait=off,nodelay`。
MONITOR=unix:$QEMU_DIR/monitor.sock,server,wait=off,nodelay
