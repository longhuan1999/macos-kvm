## 🖥️ 基本与系统配置
# 虚拟机名称（用于进程名、界面标题）
APP=macOS
# 目标平台（`x64` 或 `arm64`）
PLATFORM=x64
# 帮助链接（显示在 Web 界面底部）
SUPPORT=https://github.com/dockur/macos
# 启用调试输出（`Y`/`1` 开启）
DEBUG=N
# 存储目录（存放磁盘镜像、配置文件等）
STORAGE=/storage
# QEMU 临时文件目录（PID、socket 等）
QEMU_DIR=/run/shm
# 启用 KVM 硬件加速（若 `N` 则使用 TCG 模拟）
KVM=Y
# QEMU 机器类型（`q35` 或 `pc` 等）
MACHINE=q35
# 虚拟机 CPU 核心数（支持 `max`/`half` 自动计算）
CPU_CORES=2
# 虚拟机内存大小（支持 `max`/`half` 或数字+单位）
RAM_SIZE=2G
# 检查并自动调整内存以避免超出主机可用内存
RAM_CHECK=Y
# 优雅关机超时（秒），若设置 `QEMU_TIMEOUT` 则优先
TIMEOUT=115
# (无) | 若设置，则覆盖 `TIMEOUT`
# QEMU_TIMEOUT=
# 启用优雅 ACPI 关机（`N` 则直接退出）
SHUTDOWN=Y
# (无) | 若为 `Y`，打印每条命令的调试信息
# TRACE=
# (空) | 额外 QEMU 参数，追加到最终命令行
# ARGUMENTS=


## 💾 磁盘与存储配置
# 主磁盘大小（支持数字+单位，`max`/`half` 自动计算）
DISK_SIZE=64G
# (空) | `DISK2_SIZE` ~ `DISK6_SIZE` 第二至第六磁盘大小（若未设则不创建）
# `DISK2_SIZE` ~ `DISK6_SIZE`
# 磁盘设备类型：`blk`/`scsi`/`nvme`/`sata`/`usb`/`auto`/`none`
DISK_TYPE=blk
# 主磁盘文件名前缀（生成 `data.img` 或 `data.qcow2`）
DISK_NAME=data
# (空) → 自动检测或默认 raw | 磁盘格式：`raw` 或 `qcow2`，自动检测或默认 `raw`
# DISK_FMT=
# I/O 模式：`native`/`threads`/`io_uring`
DISK_IO=native
# 缓存模式：`none`/`writeback`/`writethrough` 等
DISK_CACHE=none
# (空) | qcow2 额外选项（如 `cluster_size=...`）
# DISK_FLAGS=
# 是否传递 TRIM 命令（`on`/`off`）
DISK_DISCARD=on
# 磁盘旋转率（`1` 为 SSD，`>1` 为 HDD）
DISK_ROTATION=1
# 预分配磁盘空间（`Y` 立即分配全部，`N` 稀疏文件）
ALLOCATE=N
# (空) | `DEVICE` ~ `DEVICE6` 直通块设备路径（如 `/dev/sdb`），优先级高于磁盘镜像
# `DEVICE` ~ `DEVICE6`
# (空) | 引导 ISO/镜像路径（若未设则使用 OpenCore 引导 macOS 恢复）
# BOOT=
# 引导设备的启动顺序索引（数字越大越后）
BOOT_INDEX=9
# (空) → 内部根据 APP 推断 | 启动模式（`macos`/`windows`/`windows_legacy` 等）
# BOOT_MODE=
# (空) → 自动选择 | 光盘设备类型（与 `DISK_TYPE` 类似）
# MEDIA_TYPE=


## 🌐 网络配置
# 是否启用网络（`N` 禁用）
NETWORK=Y
# 若为 `Y`，使用 macvtap 模式（需容器网络为 macvlan）
DHCP=N
# QEMU 网卡型号（如 `e1000`、`rtl8139`）
ADAPTER=virtio-net-pci
# (自动生成) | 虚拟机 MAC 地址（可手动指定 12 或 17 位）
# MAC=
# (自动检测) | 网络 MTU 值（若自动检测失败则默认为 0）
# MTU=
# (空) | 固定虚拟机 IP（仅用于用户模式网络）
# VM_NET_IP=
# (自动检测) | 宿主机网络接口名（如 `eth0`）
# VM_NET_DEV=
# TAP 接口名称（仅在 DHCP/NAT 模式使用）
VM_NET_TAP=qemu
# 同 `APP` | 虚拟机主机名 
# VM_NET_HOST=
# NAT 模式下桥接接口名称
VM_NET_BRIDGE=docker
# 子网掩码
VM_NET_MASK=255.0.0.0
# (空) | 逗号分隔的端口列表，这些端口将**不**被转发到虚拟机
# HOST_PORTS=
# (空) | 逗号分隔的端口列表（如 `8080/tcp`），转发到虚拟机（仅用户模式网络）
USER_PORTS=1420,1421,8080
# 用于探测虚拟机是否启动的端口（生成 URL）
CHECK_PORT=80
# passt 二进制路径
PASST=/run/passt
# (空) | passt 的 MTU 值
# PASST_MTU=
# (空) | 额外 passt 参数
# PASST_OPTS=
# (空) | 若为 `Y`，打印 passt 调试日志
# PASST_DEBUG=
# passt PID 文件路径
PASST_PID=/var/run/passt.pid
# (空) | 额外 dnsmasq 参数
# DNSMASQ_OPTS=
# (空) | 若为 `Y`，实时输出 dnsmasq 日志
# DNSMASQ_DEBUG=
# dnsmasq 二进制路径
DNSMASQ=/usr/sbin/dnsmasq
# dnsmasq PID 文件路径
DNSMASQ_PID=/var/run/dnsmasq.pid
# dnsmasq 配置目录
DNSMASQ_CONF_DIR=/etc/dnsmasq.d
# (无) | 若为 `Y`，禁用 dnsmasq（使用主机 DNS）
# DNSMASQ_DISABLE=
# (无) | 宿主机HTTP 代理（用于代理下载文件）
# HTTP_PROXY=http://172.30.0.1:7890
# HTTPS_PROXY=http://172.30.0.1:7890
# ALL_PROXY=socks5://172.30.0.1:7890
# http_proxy=http://172.30.0.1:7890
# https_proxy=http://172.30.0.1:7890
# all_proxy=socks5://172.30.0.1:7890
# GATEWAY_PROXY=http://172.30.0.1:7890


## 🖼️ 显示与 GPU
# 显示类型：`web` (VNC+WebSocket)、`vnc`、`disabled`、`none` 或直接显示类型
DISPLAY=web
# 显卡型号（如 `virtio-vga-gl` 等）
VGA=vmware
# 启用 GPU 直通（仅 Intel，需设置 `RENDERNODE`）
GPU=N
# DRM 渲染节点（GPU 直通用）
RENDERNODE=/dev/dri/renderD128
# VNC 服务端口（基数，VNC 实际端口为此值）
VNC_PORT=5900
# Nginx Web 界面端口
WEB_PORT=8006
# WebSocket 日志服务端口
WSD_PORT=8004
# VNC WebSocket 端口
WSS_PORT=5700
# (无，默认为启用) | 若设为 `N`，禁用 Web 界面（Nginx 和 WebSocket）
# WEB=
# (无) | 若为 `Y`，启用 NoVNC 密码保护（需设置 `PASS` 或 `PASSWORD`）
# PROTECT=
# (无) | HTTP 基本认证用户名（默认 `Docker`）
# USERNAME=
# (无) | 基本认证密码（默认 `admin`）
# PASSWORD/PASS=


## 🍏 macOS 专用配置
# (空) → 默认为 `14` (Sonoma) | macOS 大版本：`tahoe`/`sequoia`/`sonoma`/`ventura`/`monterey`/`bigsur`/`catalina` 或数字
# VERSION=
# 设备型号（用于生成序列号）
MODEL=iMacPro1,1
# 默认屏幕宽度
WIDTH=1920
# 默认屏幕高度
HEIGHT=1080
# (自动生成) | 系统序列号（可手动指定）
# SN=
# (自动生成) | 主板序列号（可手动指定）
# MLB=
# (自动生成) | 系统 UUID（可手动指定）
# UUID=
# 启用 UEFI 安全启动（`on`/`off`）
SECURE=off
# (无) | 若为 `N`，不替换 OVMF 启动 Logo
# LOGO=


## 🧠 内存气球（动态内存回收）
# 启用内存气球监控（`Y` 开启）
BALLOONING=N
# 气球监控调试输出
BALLOONING_DEBUG=N
# (无) → 内部默认 33% | 最小气球目标（百分比或绝对值，如 `2G`）
# BALLOONING_MIN_MEM=
# (无) → 内部默认 80.0 | 目标主机 RAM 使用率百分比
# BALLOONING_RAM_THRESHOLD=
# (无) → 内部默认 90.0 | 硬阈值，超过此值可能触发 guest 内存压力
# BALLOONING_RAM_THRESHOLD_HARD=
# (无) → 内部默认 10.0 | PSI 平均 10 秒压力开始降低气球目标的百分比
# BALLOONING_PSI_PRESSURE=
# (无) → 内部默认 50.0 | PSI 压力达到此值时气球目标降至最小值
# BALLOONING_PSI_PRESSURE_MAX=
# (无) → 内部默认 128M | 气球调整的最小变化量（大小或百分比）
# BALLOONING_HYSTERESIS=
# (无) → 内部默认 0.5 | PI 控制器比例增益
# BALLOONING_KP=
# (无) → 内部默认 0.05 | PI 控制器积分增益
# BALLOONING_KI=
# (无) → 内部默认 5 | 轮询间隔（秒）
# BALLOONING_INTERVAL=


## ⚙️ QEMU 底层参数
# 启用 HPET 时钟（`on`/`off`）
HPET=off
# 启用 VMware 回退端口（`on`/`off`）
VMPORT=off
# 串口配置（如 `telnet:...`）
SERIAL=mon:stdio
# USB 控制器配置，设为 `no` 禁用
USB=qemu-xhci,id=xhci,p2=7,p3=7
# QEMU 监视器 socket 配置
MONITOR=unix:$QEMU_DIR/monitor.sock,server,wait=off,nodelay
# SMP 拓扑（一般无需手动设置）
SMP=$CPU_CORES,sockets=1,dies=1,cores=$CPU_CORES,threads=1
# (自动选择) | CPU 型号（如 `host`、`Skylake-Client-v4`）
# CPU_MODEL=
# (自动生成) | 额外 CPU 标志（如 `+invtsc`）
# CPU_FLAGS=
# 为 Windows 启用 Hyper-V  enlightenments
HV=Y
# 禁用 VMX（用于解决某些 Windows 更新崩溃）
VMX=N
